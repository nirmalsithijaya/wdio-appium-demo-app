{
    "name": "webdriverio-tests",
    "version": "0.1.0",
    "private": true,
    "devDependencies": {
        "@wdio/allure-reporter": "^9.29.0",
        "@wdio/appium-service": "^9.29.0",
        "@wdio/browserstack-service": "^9.29.0",
        "@wdio/cli": "^9.29.0",
        "@wdio/local-runner": "^9.29.0",
        "@wdio/mocha-framework": "^9.29.0",
        "@wdio/spec-reporter": "^9.29.0",
        "allure-commandline": "^2.42.0",
        "appium": "^3.5.0",
        "appium-uiautomator2-driver": "^7.6.0",
        "appium-xcuitest-driver": "^11.9.0",
        "chromedriver": "^106.0.1",
        "wdio-chromedriver-service": "^8.0.0"
    },
    "scripts": {
        "wdioIOS": "rm -rf allure-results && wdio run config/wdio-ios.conf.js && allure open allure-report",
        "wdioAndroid": "rm -rf allure-results && wdio run config/wdio-android.conf.js && allure open allure-report",
        "wdioBrowserstack": "wdio run config/wdio-browserstack.conf.js",
        "allure:generate": "allure generate allure-results --clean -o allure-report",
        "allure:open": "allure open allure-report",
        "allure:report": "npm run allure:generate && npm run allure:open"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.104.1",
        "@google/generative-ai": "^0.24.1",
        "docx": "^9.7.1",
        "openai": "^6.42.0"
    }
}
