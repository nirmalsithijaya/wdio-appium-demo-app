    name: 'should purchase the first product successfully',
    body: {
      lang: 'ecmascript',
      code: 'async () => {\n' +
        '    // Navigate to product detail\n' +
        '    await CatalogScreen.firstStoreItem.click();\n' +
        '    await ProductDetailScreen.addToCartBtn.click();\n' +
        '\n' +
        '    // Go to cart\n' +
        '    await CatalogScreen.cartBadge.click();\n' +
        '    await expect(CartScreen.cartScreen).toBeDisplayed();\n' +
        '    await CartScreen.proceedToCheckoutBtn.click();\n' +
        '\n' +
        '    // Fill address\n' +
        '    const { fullName, addressLine1, city, state, zipCode, country } = checkoutData.address;\n' +
        '    await CheckoutScreen.fillAddress(fullName, addressLine1, city, state, zipCode, country);\n' +
