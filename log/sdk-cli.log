        '    //Access the username input element by its content-desc\n' +
        `    await $('//*[@content-desc="Username input field"]').setValue(\n` +
        '      "bob@example.com",\n' +
        '    );\n' +
        '    //Access the username input element by its class + content-desc\n' +
        '    await $(\n' +
        `      '//android.widget.EditText[@content-desc="Password input field"]',\n` +
        '    ).setValue("10203040");\n' +
        '    //Access the login button by the default xpath\n' +
        '    await $(\n' +
        `      '//android.view.ViewGroup[@content-desc="Login button"]/android.widget.TextView',\n` +
        '    ).click();\n' +
        '    // await driver.pause(3000);\n' +
        '\n' +
        '    //Access the product header element using the UISelector\n' +
        '    //https://webdriver.io/docs/selectors/#android-uiautomator\n' +
        '    //https://developer.android.com/reference/androidx/test/uiautomator/UiSelector\n' +
        '    const selector =\n' +
        `      'new UiSelector().text("Products").className("android.widget.TextView")';\n` +
        '    const productsUISelector = await $(`android=${selector}`);\n' +
        '    await expect(productsUISelector).toHaveText("Products");\n' +
        '\n' +
        '    //Logout\n' +
        '    await $("~open menu").click();\n' +
        `    await $('//*[@text="Log Out"]').click();\n` +
        '\n' +
        '    //Click Logout in the confirmation pop-up\n' +
        `    await $('//*[@text="LOG OUT"]').click();\n` +
        '\n' +
        '    //Verify logout success messsage\n' +
        '    await expect(\n' +
        `      $('//android.widget.TextView[@resource-id="android:id/alertTitle"]'),\n` +
        '    ).toHaveText("You are successfully logged out.");\n' +
        '  }'
    },
