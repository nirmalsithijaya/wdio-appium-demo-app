        '    await LeftSideMenuScreen.navigateToGeoLocation();\n' +
        '    await GeoLocationScreen.geoLocationScreen.waitForDisplayed({ timeout: 5000 });\n' +
        '\n' +
        '    const startBtn = GeoLocationScreen.startObservingBtn;\n' +
        '    if (await startBtn.isEnabled()) {\n' +
        '      await startBtn.click();\n' +
        '    }\n' +
        '\n' +
        '    await GeoLocationScreen.waitForCoordinatesToUpdate();\n' +
        '\n' +
        '    const lat = await GeoLocationScreen.latitudeValue.getText();\n' +
        '    const lon = await GeoLocationScreen.longitudeValue.getText();\n' +
        '\n' +
        '    expect(parseFloat(lat)).not.toBe(0);\n' +
        '    expect(parseFloat(lon)).not.toBe(0);\n' +
        '  }'
    },
    identifier: 'should update latitude and longitude when location permission is granted',
    scope: 'Geo Location - should update latitude and longitude when location permission is granted',
    scopes: [ 'Geo Location' ],
