          '    );\n' +
          '    //Access the username input element by its class + content-desc\n' +
          '    await $(\n' +
          `      '//android.widget.EditText[@content-desc="Password input field"]',\n` +
          '    ).setValue("10203040");\n' +
          '    //Access the login button by the default xpath\n' +
          '    await $(\n' +
          `      '//android.view.ViewGroup[@content-desc="Login button"]/android.widget.TextView',\n` +
          '    ).click();\n' +
          '    // await driver.pause(3000);\n' +
          '\n' +
          '    //Access the product header element using the UISelector\n' +
