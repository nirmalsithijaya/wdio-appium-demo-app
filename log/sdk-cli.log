    framework: 'WebdriverIO-mocha',
    uuid: '1e736b27-2d5c-4b5c-98dc-a711c41e96f6',
    name: 'should not update coordinates when location permission is denied',
    body: {
      lang: 'ecmascript',
      code: 'async () => {\n' +
        '    // Revoke permission — Android 14 force-restarts the app activity when this happens\n' +
        "    await driver.execute('mobile: changePermissions', {\n" +
        "      action: 'revoke',\n" +
        '      appPackage: APP_PACKAGE,\n' +
        '      permissions: [\n' +
        "        'android.permission.ACCESS_FINE_LOCATION',\n" +
        "        'android.permission.ACCESS_COARSE_LOCATION',\n" +
        '      ],\n' +
        '    });\n' +
        '\n' +
        '    // Re-activate and wait for Catalog screen to be ready\n' +
        '    await driver.activateApp(APP_PACKAGE);\n' +
        "    await $('~open menu').waitForDisplayed({ timeout: 8000 });\n" +
        '\n' +
        '    await LeftSideMenuScreen.navigateToGeoLocation();\n' +
        '    await GeoLocationScreen.denyLocationPermission();\n' +
        '\n' +
        '    await GeoLocationScreen.geoLocationScreen.waitForDisplayed({ timeout: 5000 });\n' +
        '\n' +
        '    const lat = await GeoLocationScreen.latitudeValue.getText();\n' +
        '    const lon = await GeoLocationScreen.longitudeValue.getText();\n' +
        '\n' +
        "    expect(lat).toBe('0');\n" +
        "    expect(lon).toBe('0');\n" +
        '  }'
    },
    identifier: 'should not update coordinates when location permission is denied',
    scope: 'Geo Location - should not update coordinates when location permission is denied',
    scopes: [ 'Geo Location' ],
    file_name: 'test/specs/android/geoLocation.e2e.js',
