      code: 'async () => {\n' +
        '    await driver.setGeoLocation({ latitude: 37.4219983, longitude: -122.084, altitude: 10 });\n' +
        '\n' +
        '    await LeftSideMenuScreen.navigateToGeoLocation();\n' +
        '    await GeoLocationScreen.geoLocationScreen.waitForDisplayed({ timeout: 5000 });\n' +
        '\n' +
        '    const startBtn = GeoLocationScreen.startObservingBtn;\n' +
        '    if (await startBtn.isEnabled()) {\n' +
        '      await startBtn.click();\n' +
        '    }\n' +
        '\n' +
        '    await GeoLocationScreen.waitForCoordinatesToUpdate();\n' +
        '\n' +
        '    const latBefore = await GeoLocationScreen.latitudeValue.getText();\n' +
        '    const lonBefore = await GeoLocationScreen.longitudeValue.getText();\n' +
        '\n' +
        '    await GeoLocationScreen.stopObservingBtn.click();\n' +
        '    await driver.pause(2000);\n' +
        '\n' +
        '    const latAfter = await GeoLocationScreen.latitudeValue.getText();\n' +
        '    const lonAfter = await GeoLocationScreen.longitudeValue.getText();\n' +
        '\n' +
        '    expect(latAfter).toBe(latBefore);\n' +
        '    expect(lonAfter).toBe(lonBefore);\n' +
        '    await expect(GeoLocationScreen.startObservingBtn).toBeEnabled();\n' +
        '  }'
    },
    identifier: 'should stop updating coordinates when Stop Observing is tapped',
    scope: 'Geo Location - should stop updating coordinates when Stop Observing is tapped',
