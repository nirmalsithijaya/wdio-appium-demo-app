        '      appPackage: APP_PACKAGE,\n' +
        '      permissions: [\n' +
        "        'android.permission.ACCESS_FINE_LOCATION',\n" +
        "        'android.permission.ACCESS_COARSE_LOCATION',\n" +
        '      ],\n' +
        '    });\n' +
        '\n' +
        '    // Re-activate and wait for Catalog screen to be ready\n' +
        '    await driver.activateApp(APP_PACKAGE);\n' +
        "    await $('~open menu').waitForDisplayed({ timeout: 8000 });\n" +
        '\n' +
        '    await LeftSideMenuScreen.navigateToGeoLocation();\n' +
        '    await GeoLocationScreen.denyLocationPermission();\n' +
        '\n' +
        '    await GeoLocationScreen.geoLocationScreen.waitForDisplayed({ timeout: 5000 });\n' +
        '\n' +
        '    const lat = await GeoLocationScreen.latitudeValue.getText();\n' +
        '    const lon = await GeoLocationScreen.longitudeValue.getText();\n' +
        '\n' +
        "    expect(lat).toBe('0');\n" +
        "    expect(lon).toBe('0');\n" +
        '  }'
    },
